<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Vista: Empleado -->
<BorderPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="dev.danipraivet.controlador.ControladorEmpleado"
        style="-fx-background-color: #F5F5F5;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1565C0; -fx-padding: 12 24;">
            <Label text="Control de Asistencia"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblFechaHora"
                   style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 13px;"/>
            <Button text="Cerrar sesion" onAction="#onLogout"
                    style="-fx-background-color: rgba(255,255,255,0.15);
                           -fx-text-fill: white; -fx-cursor: hand;
                           -fx-background-radius: 4;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 28;">

            <Label fx:id="lblBienvenida"
                   text="Bienvenido"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212121;"/>

            <!-- Tarjeta de fichaje -->
            <VBox alignment="CENTER" spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);
                         -fx-padding: 32;">

                <Label fx:id="lblEstadoFichaje"
                       text="Cargando estado..."
                       style="-fx-font-size: 16px; -fx-text-fill: #757575;"/>

                <Button fx:id="btnFichar"
                        text="Entrada"
                        onAction="#onFichar"
                        style="-fx-background-color: #43a047; -fx-text-fill: white;
                               -fx-font-size: 18px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-pref-width: 220px;
                               -fx-pref-height: 56px; -fx-cursor: hand;"/>
            </VBox>

            <!-- Historial del mes -->
            <VBox spacing="8"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);
                         -fx-padding: 20;" VBox.vgrow="ALWAYS">

                <Label text="Mi historial - mes actual"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #212121;"/>

                <TableView fx:id="tablaHistorial" prefHeight="320" maxWidth="Infinity"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFecha"   text="Fecha"   prefWidth="110"/>
                        <TableColumn fx:id="colEntrada" text="Entrada" prefWidth="80"/>
                        <TableColumn fx:id="colSalida"  text="Salida"  prefWidth="80"/>
                        <TableColumn fx:id="colTurno"   text="Turno"   prefWidth="90"/>
                        <TableColumn fx:id="colHoras"   text="Horas"   prefWidth="90"/>
                        <TableColumn fx:id="colEstado"  text="Estado"  prefWidth="120"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Label fx:id="lblTotalHorasMes"
                           text="Total mes: 0 h"
                           style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1565C0;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
